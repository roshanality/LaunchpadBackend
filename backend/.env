# ── JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-string

# ── SMTP (Gmail example) ──────────────────────────────
# For Gmail: enable "App Passwords" in your Google account
# and paste the 16-character app password below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_NAME=KGP Launchpad
